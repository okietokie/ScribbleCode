```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Logs and temp files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/

# OS generated files
.DS_Store
Thumbs.db
```